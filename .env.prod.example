# =============================================================
# OSMECH — Variáveis de produção (Hostinger VPS)
# Copie para .env.prod e preencha com os valores reais
# NUNCA versione este arquivo com valores reais
# =============================================================

# Banco
DB_USERNAME=osmech
DB_PASSWORD=SENHA_FORTE_AQUI

# JWT — gere com: openssl rand -base64 64
JWT_SECRET=GERE_UM_SECRET_FORTE_AQUI
JWT_EXPIRATION=86400000

# CORS — domínio do seu site na Hostinger
CORS_ORIGINS=https://seudominio.com.br

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
MERCADOPAGO_PUBLIC_KEY=APP_USR-...
MERCADOPAGO_SUCCESS_URL=https://seudominio.com.br/assinatura/sucesso
MERCADOPAGO_PENDING_URL=https://seudominio.com.br/assinatura/pendente
MERCADOPAGO_FAILURE_URL=https://seudominio.com.br/assinatura/falha
MERCADOPAGO_NOTIFICATION_URL=https://seudominio.com.br/api/mercadopago/webhook
MERCADOPAGO_WEBHOOK_SECRET=GERE_UM_SECRET_AQUI

# IA (opcional)
AI_ENABLED=true
AI_PROVIDER=gemini
AI_OPENAI_API_KEY=SUA_CHAVE_GEMINI
AI_OPENAI_MODEL=gemini-1.5-flash
AI_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
