*.secret
*.secrets
secrets/
credentials/

# === Arquivos de credenciais soltos na raiz (nomes com = são variáveis de ambiente acidentais) ===
DB_PASSWORD=*
DB_USERNAME=*
JWT_SECRET=*
MERCADOPAGO_ACCESS_TOKEN=*
MERCADOPAGO_PUBLIC_KEY=*
MERCADOPAGO_WEBHOOK_SECRET=*
AI_OPENAI_API_KEY=*
VAULT_TOKEN=*
# Qualquer arquivo na raiz cujo nome contenha = (padrão de variável de ambiente)
/*=*

# === Logs de execução locais ===
*-out.log
*-err.log
