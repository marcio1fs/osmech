# =========================
# OSMECH Backend - example
# =========================

SPRING_PROFILES_ACTIVE=dev
PORT=8081

# Banco
DB_URL=jdbc:postgresql://localhost:5432/oficina_db
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME
JPA_DDL_AUTO=update

# JWT
JWT_SECRET=YOUR_VERY_SECURE_JWT_SECRET_KEY_AT_LEAST_32_BYTES_LONG
JWT_EXPIRATION=86400000

# CORS
CORS_ORIGINS=http://localhost:8083,http://localhost:3000

# Flyway
FLYWAY_ENABLED=false
FLYWAY_BASELINE_ON_MIGRATE=true
FLYWAY_BASELINE_VERSION=1

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=CHANGE_ME
MERCADOPAGO_PUBLIC_KEY=CHANGE_ME
MERCADOPAGO_SUCCESS_URL=http://localhost:8083/assinatura/sucesso
MERCADOPAGO_PENDING_URL=http://localhost:8083/assinatura/pendente
MERCADOPAGO_FAILURE_URL=http://localhost:8083/assinatura/falha
MERCADOPAGO_NOTIFICATION_URL=https://your-domain.com/api/mercadopago/webhook
MERCADOPAGO_WEBHOOK_SECRET=CHANGE_ME

# IA Assistente
AI_ENABLED=false
AI_PROVIDER=openai
AI_OPENAI_API_KEY=CHANGE_ME
AI_OPENAI_MODEL=gpt-4o-mini
AI_OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
